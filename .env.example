VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Лише `npm run dev`: повний публічний UI з демо-даними без звернення до Supabase (URL/key можна не задавати).
# VITE_DEMO_MODE=true

# Local dev only: unlock /admin UI without DB role (RPCs may still 403; never set in production)
# VITE_DEV_MOCK_ADMIN=true
#
# Local dev: no JWT — UI "logged in" + in-memory profile row (any valid UUID, not required to exist in DB)
# VITE_DEV_MOCK_USER_ID=00000000-0000-4000-8000-000000000000

# Optional: Sentry browser SDK (leave empty for local dev)
VITE_SENTRY_DSN=

# CI source maps upload (Sentry Vite plugin); optional
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
